<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>

<BorderPane prefHeight="700" prefWidth="1100" style="-fx-background-color: #16161e;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.lost_and_found_application.Controller.ItemDetailsController">

    <center>
        <GridPane alignment="CENTER" hgap="30" maxHeight="480" maxWidth="820" style="-fx-background-color: #1e1e2a;                          -fx-background-radius: 18;                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 25, 0.2, 0, 8);" vgap="0">

            <padding>
                <Insets bottom="32" left="36" right="36" top="32" />
            </padding>

            <columnConstraints>
                <ColumnConstraints percentWidth="38" />
                <ColumnConstraints percentWidth="62" />
            </columnConstraints>

            <!-- Image -->
            <StackPane prefHeight="360" style="-fx-background-color: #16161e;                               -fx-background-radius: 14;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <ImageView fx:id="itemImageView" fitHeight="340" fitWidth="280" preserveRatio="true" />
            </StackPane>

            <!-- Details -->
            <GridPane vgap="14" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <padding>
                    <Insets left="10" />
                </padding>

                <Label fx:id="itemNameLabel" style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;" text="Laptop" GridPane.columnIndex="0" GridPane.rowIndex="0" />

                <Label fx:id="statusBadge" style="-fx-background-color: rgba(255,107,107,0.15);                               -fx-text-fill: #ff6b6b;                               -fx-background-radius: 20;                               -fx-padding: 4 14 4 14;                               -fx-font-size: 11px;                               -fx-font-weight: bold;" text="Lost" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <GridPane.margin><Insets bottom="6" /></GridPane.margin>
                </Label>

                <Label style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 10px; -fx-font-weight: bold;" text="CATEGORY" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <Label fx:id="categoryLabel" style="-fx-text-fill: white; -fx-font-size: 14px;" text="Electronics" GridPane.columnIndex="0" GridPane.rowIndex="3" />

                <Label style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 10px; -fx-font-weight: bold;" text="LOCATION" GridPane.columnIndex="0" GridPane.rowIndex="4">
                    <GridPane.margin><Insets top="6" /></GridPane.margin>
                </Label>
                <Label fx:id="locationLabel" style="-fx-text-fill: white; -fx-font-size: 14px;" text="Library, 2nd Floor" GridPane.columnIndex="0" GridPane.rowIndex="5" />

                <Label style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 10px; -fx-font-weight: bold;" text="REPORTED ON" GridPane.columnIndex="0" GridPane.rowIndex="6">
                    <GridPane.margin><Insets top="6" /></GridPane.margin>
                </Label>
                <Label fx:id="reportedDateLabel" style="-fx-text-fill: white; -fx-font-size: 14px;" text="July 5, 2026" GridPane.columnIndex="0" GridPane.rowIndex="7" />

                <Label style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 10px; -fx-font-weight: bold;" text="DESCRIPTION" GridPane.columnIndex="0" GridPane.rowIndex="8">
                    <GridPane.margin><Insets top="6" /></GridPane.margin>
                </Label>
                <Label fx:id="descriptionLabel" maxWidth="380" style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 13px;" text="Silver 14-inch laptop with a cracked corner sticker, left near the reading area." wrapText="true" GridPane.columnIndex="0" GridPane.rowIndex="9" />
            <columnConstraints>
               <ColumnConstraints />
            </columnConstraints>
            <rowConstraints>
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
            </rowConstraints>
            </GridPane>

            <!-- Action Buttons -->
            <HBox alignment="CENTER_LEFT" spacing="10" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="1">
                <GridPane.margin><Insets top="26" /></GridPane.margin>

                <Button fx:id="backButton" onAction="#handleBack" prefHeight="42" prefWidth="100" style="-fx-background-color: transparent;                                -fx-text-fill: rgba(255,255,255,0.6);                                -fx-border-color: rgba(255,255,255,0.2);                                -fx-border-radius: 10;                                -fx-background-radius: 10;                                -fx-font-size: 12px;                                -fx-cursor: hand;" text="←  Back" />

                <Region HBox.hgrow="ALWAYS" />

                <Button fx:id="editButton" onAction="#handleEdit" prefHeight="42" prefWidth="100" style="-fx-background-color: #2a2a38;                                -fx-text-fill: white;                                -fx-background-radius: 10;                                -fx-font-size: 12px;                                -fx-cursor: hand;" text="Edit" />
            </HBox>
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>
        </GridPane>
    </center>
</BorderPane>
